# PostgreSQL
POSTGRES_USER=dma_user
POSTGRES_PASSWORD=dma_secret
POSTGRES_DB=dma_main

# Orchestrator (FastAPI)
DATABASE_URL=postgresql+asyncpg://dma_user:dma_secret@postgres:5432/dma_main
TEST_DATABASE_URL=postgresql+asyncpg://dma_user:dma_secret@postgres:5432/dma_test
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Frontend (Laravel)
APP_NAME="Data Model Agent"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
ORCHESTRATOR_URL=http://orchestrator:8000
